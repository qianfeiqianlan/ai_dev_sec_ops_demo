{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "coverage/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {},
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:cov:ci": {
      "dependsOn": ["^build"],
      "outputs": ["../../coverage/**", "coverage/**"]
    },
    "test:e2e:ci": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
