{
  "name": "ai_dev_sec_ops_demo",
  "version": "0.1.0",
  "description": "NestJS monorepo demo for GitHub-based CR/MR and CI/CD DevSecOps workflows.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "format": "prettier --write --no-error-on-unmatched-pattern \"apps/**/*.ts\" \"packages/**/*.ts\" \"apps/**/*.mjs\" \"packages/**/*.mjs\" \"scripts/**/*.mjs\" \"*.cjs\" \"*.md\" \"docs/**/*.md\" \"*.json\" \"*.yml\" \".github/**/*.yml\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"apps/**/*.ts\" \"packages/**/*.ts\" \"apps/**/*.mjs\" \"packages/**/*.mjs\" \"scripts/**/*.mjs\" \"*.cjs\" \"*.md\" \"docs/**/*.md\" \"*.json\" \"*.yml\" \".github/**/*.yml\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "spell": "cspell --no-progress .",
    "start": "pnpm --filter @ai-devsecops/api run start",
    "start:dev": "pnpm --filter @ai-devsecops/api run start:dev",
    "start:debug": "pnpm --filter @ai-devsecops/api run start:debug",
    "start:prod": "pnpm --filter @ai-devsecops/api run start:prod",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:cov:ci": "turbo run test:cov:ci",
    "test:e2e": "pnpm --filter @ai-devsecops/api run test:e2e",
    "test:e2e:ci": "pnpm --filter @ai-devsecops/api run test:e2e:ci",
    "audit:deps": "pnpm audit --audit-level moderate",
    "policy:pr": "node scripts/check-pr-policy.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "cspell": "^10.0.1",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "turbo": "^2.6.3"
  }
}
